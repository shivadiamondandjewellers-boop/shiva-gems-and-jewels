  .nav-cta:hover { background: var(--rose-gold); color: var(--deep-plum); }
  .hero { min-height: 100vh; background: var(--deep-plum); display: flex; align-items: center; justify-content: center; text-align: center; color: #fff; padding: 120px 20px; }
  .hero-h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 8vw, 80px); font-weight: 300; margin-bottom: 20px; }
  .hero-h1 em { font-style: italic; color: var(--rose-gold); }
  .btn-primary { background: var(--rose-gold); color: var(--deep-plum); padding: 16px 40px; text-decoration: none; text-transform: uppercase; font-size: 11px; letter-spacing: 2px; font-weight: 600; display: inline-block; margin-top: 30px; }
  footer { background: var(--charcoal); color: rgba(255,255,255,0.5); padding: 40px; text-align: center; font-size: 12px; }
</style>
</head>
